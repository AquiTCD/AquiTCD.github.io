---
import Layout from '../layouts/Layout.astro';
---

<Layout title="The Portfolio of Aqui.TCD">
	<main>
		<div class="portal">
			<h1>Aqui.TCD Portal</h1>
			<p>Renewal in progress...</p>

		</div>
	</main>
</Layout>

<style>
	main {
		margin: auto;
		padding: 2rem;
		width: 800px;
		max-width: calc(100% - 2rem);
		color: white;
		font-family: system-ui, sans-serif;
	}
	.portal {
		background: rgba(0,0,0,0.8);
		padding: 2rem;
		border: 4px solid #E60012; /* P5 Red */
		transform: rotate(-1deg);
	}
	h1 {
		font-size: 3rem;
		color: #E60012;
		margin-bottom: 1rem;
		text-transform: uppercase;
		text-shadow: 2px 2px 0 #fff;
	}
	a {
		color: white;
		font-size: 1.5rem;
		text-decoration: none;
		display: inline-block;
		margin-top: 1rem;
		padding: 0.5rem 1rem;
		background: #E60012;
		font-weight: bold;
		transition: transform 0.1s;
	}
	a:hover {
		transform: scale(1.05) rotate(1deg);
		color: #000;
		background: #fff;
	}
</style>
